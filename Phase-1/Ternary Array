#include <stdio.h>
#include <stdlib.h>

int main() {
int n;
scanf("%d",&n);
int a[n];
for ( int i=0;i<n;i++)
{
    scanf("%d",&a[i]);
}
long long cost=0;
for ( int i=0;i<n;i++)
{
 int best=1e9;
    for (int b=0;b<=2;b++)
    {
        if(a[i]==b)
    continue;
    int diff=abs(a[i]-b);
    if(diff<best){
    best=diff;
    }
}
cost+=best;
}
printf("%lld",cost);
   
    return 0;
}
