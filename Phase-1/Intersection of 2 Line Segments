#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin>>t;
    while(t--)
    {
        long long x1,y1,x2,y2,x3,y3,x4,y4;
        cin>>x1>>y1>>x2>>y2>>x3>>y3>>x4>>y4;
        long long a=(x2-x1)*(y3-y1)-(y2-y1)*(x3-x1);
        long long b=(x2-x1)*(y4-y1)-(y2-y1)*(x4-x1);
        long long c=(x4-x3)*(y1-y3)-(y4-y3)*(x1-x3);
        long long d=(x4-x3)*(y2-y3)-(y4-y3)*(x2-x3);
        cout<<((a*b<=0 && c*d<=0)?"Yes\n":"No\n");
    }
    return 0;
}
