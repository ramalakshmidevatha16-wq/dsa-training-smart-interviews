#include <stdio.h>
#include <stdlib.h>
int  main(){
int N;
scanf("%d",&N);
int arr[N];
for(int i=0;i<N;i++)
{
  scanf("%d",&arr[i]);
}
for(int gap=N/2;gap>0;gap/=2)
{
  for(int i=gap;i<N;i++)
  {
    int temp=arr[i];
    int j=i;
    while(j>= gap && arr[j-gap]>temp)
    {
      arr[j]=arr[j-gap];
      j-=gap;
    }
    arr[j]=temp;
  }
  for(int i=0;i<N;i++)
  {printf("%d ",arr[i]);
  }
  printf("\n");}
  return 0;
  
}
