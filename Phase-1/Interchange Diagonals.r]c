#include <stdio.h>
#include <stdlib.h>

int main() {

    int n;
    scanf("%d",&n);
    int mat[n][n];
    for (int i=0;i<n;i++)
    {
        for (int j=0;j<n;j++)
        {
            scanf("%d",&mat[i][j]);
        }
    }
    for (int i=0;i<n;i++)
    {
      int temp=mat[i][i];
      mat[i][i]=mat[i][n-1-i];
      mat[i][n-1-i]=temp;
       
    }
    for (int i=0;i<n;i++)
    {
        for ( int j=0;j<n;j++)
        {
            printf("%d ",mat[i][j]);
        }
         printf("\n");
    }
    return 0;
}
